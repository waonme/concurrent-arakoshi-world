{
    "name": "concrnt-world-workspace",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "build": "pnpm -r build",
        "dev": "pnpm --filter concrnt-world dev"
    },
    "dependencies": {
        "@concrnt/client": "^0.0.3"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.2.0",
        "@eslint/js": "^9.19.0",
        "eslint": "^9.19.0",
        "eslint-plugin-react": "^7.37.4",
        "globals": "^15.14.0",
        "husky": "^9.1.7",
        "lint-staged": "^15.4.3",
        "prettier": "^3.4.2",
        "typescript": "^5.7.3"
    },
    "packageManager": "pnpm@8.6.1",
    "volta": {
        "node": "22.12.0"
    },
    "lint-staged": {
        "app/**/*.{js,jsx,ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "client/**/*.{js,jsx,ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ]
    }
}
